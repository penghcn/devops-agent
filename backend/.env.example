# Jenkins 配置
# 1. 登录 Jenkins，点击右上角用户名 → 左侧菜单选择 "Configure" 或 "设置"
# 2. 找到 "API Token" 区域
# 3. 点击 "Add new Token" 按钮
JENKINS_URL=http://<jenkins-host>:<port>/jenkins/
JENKINS_USER=<your-jenkins-username>
JENKINS_TOKEN=<your-jenkins-api-token>

# GitLab 配置
# 1. 登录 GitLab，点击右上角头像 → "Preferences" 或 "Edit Profile"
# 2. 左侧菜单选择 "Access Tokens"
# 3. 填写 Token 名称（如 "rust-agent"）
# 4. 设置过期时间（建议 30 天，不设则永不过期）
# 5. 勾选权限范围（Scopes）：
#   ✅ api          # 完整 API 访问（推荐）
#   ✅ read_repository   # 读取仓库
#   ✅ write_repository  # 写入仓库
# 6. 点击 "Create personal access token"

GITLAB_URL=http://<gitlab-host>
GITLAB_TOKEN=<your-gitlab-personal-access-token>

# Claude Code 路径（默认 PATH 中能找到即可）
CLAUDE_CODE_PATH=claude
